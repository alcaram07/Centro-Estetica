<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pati C Estética</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css?v=2" asp-append-version="true" />
    <link rel="stylesheet" href="~/AestheticCenter.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-nude border-bottom sticky-top py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-page="/Index">
                    <img src="~/images/logo-patic.png" alt="Logo Pati C" width="48" height="48" class="rounded-circle shadow-sm logo-blend" asp-append-version="true" />
                    <div>
                        <div class="nav-brand">Pati C</div>
                        <div class="nav-sub">Estética · Cosmetología</div>
                    </div>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 justify-content-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Services/Index">Servicios</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold" asp-page="/Admin/Appointments">Citas Admin</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold" asp-page="/Admin/Services/Index">Servicios Admin</a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                    <a href="https://wa.me/598096045127" target="_blank" class="nav-cta ms-lg-3 mt-3 mt-lg-0 text-center text-decoration-none">Reservar turno</a>
                </div>
            </div>
        </nav>
    </header>
    <div class="main-wrapper">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-dark py-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <span>© 2026 · Pati C Estética & Cosmetología · Montevideo</span>
                </div>
                <div class="col-md-6 text-center text-md-end footer-links">
                    <a href="https://instagram.com/pati.c.estetica" target="_blank" class="me-3">Instagram</a>
                    <a asp-page="/Privacy" class="me-3">Privacidad</a>
                    <a href="mailto:info@aestheticcenter.com">Contacto</a>
                </div>
            </div>
        </div>
    </footer>

    <a href="https://wa.me/598096045127?text=Hola%20Patricia%2C%20quiero%20consultar%20sobre%20los%20servicios"
       target="_blank" class="wa-float shadow" title="Escribir por WhatsApp">
        <i class="bi bi-whatsapp"></i>
    </a>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
