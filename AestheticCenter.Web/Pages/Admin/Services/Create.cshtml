@page
@model AestheticCenter.Web.Pages.Admin.Services.CreateModel
@{
    ViewData["Title"] = "Crear Nuevo Servicio";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white py-3">
                <h2 class="mb-0 fs-4">Añadir Nuevo Servicio</h2>
            </div>
            <div class="card-body p-4">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Service.Name" class="form-label">Nombre del Servicio</label>
                        <input asp-for="Service.Name" class="form-control" placeholder="Ej: Tratamiento de Hidratación" />
                        <span asp-validation-for="Service.Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Service.Description" class="form-label">Descripción</label>
                        <textarea asp-for="Service.Description" class="form-control" rows="3" placeholder="Describe brevemente el tratamiento..."></textarea>
                        <span asp-validation-for="Service.Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Service.Price" class="form-label">Precio (€)</label>
                            <input asp-for="Service.Price" class="form-control" type="number" step="0.01" />
                            <span asp-validation-for="Service.Price" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Service.DurationMinutes" class="form-label">Duración (minutos)</label>
                            <input asp-for="Service.DurationMinutes" class="form-control" type="number" />
                            <span asp-validation-for="Service.DurationMinutes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">Guardar Servicio</button>
                        <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
