@page
@model AestheticCenter.Web.Pages.Admin.Services.IndexModel
@{
    ViewData["Title"] = "Gestión de Servicios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Gestión de Servicios</h1>
        <p class="text-muted">Añade o modifica los tratamientos que ofreces.</p>
    </div>
    <a asp-page="./Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nuevo Servicio
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Precio</th>
                    <th>Duración</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var service in Model.Services)
                {
                    <tr>
                        <td class="fw-bold">@service.Name</td>
                        <td class="text-muted small">@service.Description</td>
                        <td>@service.Price.ToString("C")</td>
                        <td>@service.DurationMinutes min</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a asp-page="./Edit" asp-route-id="@service.Id" class="btn btn-outline-secondary" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-page="./Delete" asp-route-id="@service.Id" class="btn btn-outline-danger" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
}
