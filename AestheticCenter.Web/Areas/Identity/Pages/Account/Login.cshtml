@page
@model AestheticCenter.Web.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0 p-4" style="border-radius: 24px;">
                <div class="text-center mb-4">
                    <img src="~/images/logo-patic.png" alt="Logo Pati C" width="80" height="80" class="mx-auto mb-3 rounded-circle shadow-sm" asp-append-version="true" />
                    <h1 class="section-title fs-3 mb-2">Bienvenida</h1>
                    <p class="text-muted small">Inicia sesión para gestionar tus citas</p>
                </div>

                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="nombre@ejemplo.com" style="border-radius: 12px;" />
                        <label asp-for="Input.Email">Correo electrónico</label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="contraseña" style="border-radius: 12px;" />
                        <label asp-for="Input.Password">Contraseña</label>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="checkbox mb-3 d-flex justify-content-between align-items-center">
                        <label asp-for="Input.RememberMe" class="form-label small text-muted">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            Recordarme
                        </label>
                        <a id="forgot-password" asp-page="./ForgotPassword" class="small text-rosa text-decoration-none">¿Olvidaste la contraseña?</a>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button id="login-submit" type="submit" class="btn btn-primary btn-lg rounded-pill">Entrar</button>
                    </div>

                    <div class="text-center mt-4 pt-2 border-top">
                        <p class="small text-muted mb-0">¿No tienes cuenta? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-rosa fw-bold text-decoration-none">Regístrate aquí</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
